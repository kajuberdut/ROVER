---
users:
  admin:
    displayname: "Administrator"
    # Password hash generated by: setup.sh (or manually via `docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'yourpassword'`)
    password: "PLACEHOLDER_ADMIN_PASSWORD_HASH"
    email: admin@rover.local
    groups:
      - admins
      - users
